generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  loginDevices  LoginDevice[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Order {
  id              String      @id @default(dbgenerated("gen_random_uuid()"))
  order_number    String?     @unique(map: "unique_order_number") @default(dbgenerated("generate_order_number()"))

  full_name       String
  phone           String

  address         String
  province        String
  district        String
  subdistrict     String
  postal_code     String

  shipping_method String

  subtotal        Float
  tax             Float
  total           Float

  created_at      DateTime    @default(now())

  order_items     OrderItem[]

  @@map("orders")
}

model OrderItem {
  id           String @id @default(dbgenerated("gen_random_uuid()"))
  order_id     String
  product_id   Int
  product_name String
  quantity     Int
  price        Float
  order        Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model DiscountCode {
  id               String   @id @default(uuid())
  code             String   @unique
  discount_percent Int
  active           Boolean  @default(true)
  created_at       DateTime @default(now())

  @@map("discount_codes")
}

model DiscountUsage {
  id         String   @id @default(uuid())
  phone      String
  code       String
  created_at DateTime @default(now())

  @@unique([phone, code])
  @@map("discount_usage")
}

model LoginDevice {
  id        String   @id @default(cuid())
  userId    String
  ip        String
  device    String
  browser   String
  os        String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
